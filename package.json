{
  "name": "helix",
  "version": "0.2.0",
  "private": true,
  "main": "electron/main.js",
  "bin": {
    "helix": "./src/cli/index.mjs"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "echo 'No linter configured'",
    "cli": "node src/cli/index.mjs",
    "electron": "electron .",
    "electron:dev": "concurrently \"next dev -p 3000\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:preview": "next build && electron-builder --dir"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "^16.1.1",
    "playwright": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.helix.desktop",
    "productName": "Helix",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "public/Helix.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "public/Helix.ico",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "public/Helix.ico",
      "target": [
        "AppImage"
      ]
    }
  }
}
