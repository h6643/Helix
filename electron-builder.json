{
  "appId": "com.helix.desktop",
  "productName": "Helix",
  "asar": true,
  "asarUnpack": [
    "node_modules/node-pty/**",
    "node_modules/@xterm/**"
  ],
  "npmRebuild": true,
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*"
  ],
  "extraResources": [
    {
      "from": ".next/standalone",
      "to": ".next/standalone"
    },
    {
      "from": ".next/static",
      "to": ".next/standalone/.next/static"
    },
    {
      "from": "public",
      "to": ".next/standalone/public"
    }
  ],
  "win": {
    "icon": "public/Helix.ico",
    "target": [
      "nsis",
      "portable"
    ]
  },
  "mac": {
    "icon": "public/Helix.ico",
    "target": [
      "dmg"
    ]
  },
  "linux": {
    "icon": "public/Helix.ico",
    "target": [
      "AppImage"
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true
  }
}
